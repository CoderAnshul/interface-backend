						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Breaking News: Technology Update\",\n  \"summary\": \"A brief summary of the news article\",\n  \"content\": \"Full content of the news article...\",\n  \"source\": {\n    \"id\": \"source-id-123\",\n    \"name\": \"News Source Name\",\n    \"url\": \"https://example.com/source\"\n  },\n  \"author\": {\n    \"name\": \"Author Name\",\n    \"profileUrl\": \"https://example.com/author\"\n  },\n  \"url\": \"https://example.com/news/article\",\n  \"imageUrl\": \"https://example.com/image.jpg\",\n  \"videoUrl\": \"\",\n  \"publishedAt\": \"2024-01-15T10:00:00Z\",\n  \"language\": \"en\",\n  \"country\": \"US\",\n  \"categories\": [\"technology\", \"science\"],\n  \"tags\": [\"AI\", \"innovation\"],\n  \"sentiment\": {\n    \"score\": 0.8,\n    \"label\": \"positive\"\n  },\n  \"entities\": {\n    \"persons\": [\"John Doe\"],\n    \"organizations\": [\"Tech Corp\"],\n    \"locations\": [\"San Francisco\"]\n  },\n  \"isBreaking\": false,\n  \"isPremium\": false,\n  \"status\": \"active\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/news",
							"host": ["{{baseUrl}}"],
							"path": ["news"]
